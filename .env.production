# ============================================================
# PRODUCTION ENVIRONMENT — All required vars must be set
# Copy this file and fill in real values before deploying
# ============================================================

# Environment
ENVIRONMENT=production

# Database (use strong password!)
POSTGRES_DB=seo_dashboard
POSTGRES_USER=seo_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://seo_user:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/seo_dashboard

# JWT (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE

# CORS — your production domain(s), comma-separated
CORS_ORIGINS=https://yourdomain.com

# LLM Provider
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-xxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Frontend
NEXT_PUBLIC_API_URL=https://yourdomain.com

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
NOTIFY_EMAIL=
