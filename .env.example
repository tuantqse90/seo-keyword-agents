# Environment: "development" or "production"
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://seo_user:seo_password@localhost:5432/seo_dashboard

# LLM Provider: "anthropic" or "deepseek"
LLM_PROVIDER=deepseek

# Anthropic (if using)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Claude model (if using anthropic)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Auth (auto-generated in dev, REQUIRED in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# Email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@seo-dashboard.local
NOTIFY_EMAIL=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
